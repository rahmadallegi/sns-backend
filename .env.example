# Server Configuration
PORT=3000
NODE_ENV=development

# Database (MySQL) - REQUIRED
# WARNING: All database variables must be set in production
DB_HOST=localhost
DB_USER=root
DB_PASS=your_password
DB_NAME=sns_db

# CORS Configuration
# REQUIRED: Set to your frontend URL in production (no trailing slash)
# Example: https://yourdomain.com
CORS_ORIGIN=http://localhost:5173

# JWT Authentication - REQUIRED IN PRODUCTION
# CRITICAL: Generate a long random string for production
# Example: openssl rand -base64 32
# DO NOT use the default value in production
JWT_SECRET=your_jwt_secret_change_in_production

# Upload Directory (Optional)
# Specify custom upload directory path. If not set, defaults to ./uploads/clients
# UPLOAD_DIR=/var/uploads

# Uploads URL Prefix (Optional)
# Customize the URL prefix for uploaded files. If not set, defaults to /uploads
# UPLOADS_URL_PREFIX=/static/uploads

# Admin Setup Token (Optional)
# Use to allow POST /api/admin/auth/register when admins already exist
# Send header: X-Admin-Setup-Token: <same value as below>
# ADMIN_SETUP_TOKEN=long_random_secret_only_for_trusted_setup
